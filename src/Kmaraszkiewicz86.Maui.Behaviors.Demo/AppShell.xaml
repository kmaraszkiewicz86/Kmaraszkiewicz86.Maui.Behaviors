<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Kmaraszkiewicz86.Maui.Behaviors.Demo.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Kmaraszkiewicz86.Maui.Behaviors.Demo"
    Title="Kmaraszkiewicz86.Maui.Behaviors.Demo">

    <ShellContent
        Title="MainPage with standard MVVM"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage with standard MVVM" />

    <ShellContent
        Title="MainPage with Community Toolkit MVVM"
        ContentTemplate="{DataTemplate local:MainPageCommunityToolkitMvvm}"
        Route="MainPage with Community Toolkit MVVM" />

</Shell>
